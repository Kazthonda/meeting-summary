# IBM Service Essentials API Configuration (for meeting minutes generation)
# https://servicesessentials.ibm.com/apis/v3
IBM_API_KEY=your-ibm-api-key-here
IBM_SERVICE_ID=consulting-advantage

# ===== Whisper Configuration =====

# Whisper Model Size (tiny, base, small, medium, large)
# Default: base (推奨: 日本語の精度とバランス)
# tiny: 最速（精度は低め）
# base: バランス型（推奨）
# small/medium: 高精度（時間がかかる）
# large: 最高精度（最も時間がかかる）
WHISPER_MODEL=base

# 高速化オプション: faster-whisper を使用 (true/false)
# faster-whisper のインストール: pip install faster-whisper
# Default: false (openai-whisper を使用)
USE_FASTER_WHISPER=false

# キャッシング有効 (true/false)
# 同じ音声ファイルの重複処理を避ける
# Default: true
ENABLE_CACHE=true

# ===== Server Configuration =====

# Server Port (default: 3000)
PORT=3000

# Environment (development/production)
NODE_ENV=development

# ===== Performance Tuning =====

# GPU メモリ最適化（faster-whisper 使用時）
# int8, int8_float16, float16, float32
# Default: auto (自動判定)
COMPUTE_TYPE=auto
